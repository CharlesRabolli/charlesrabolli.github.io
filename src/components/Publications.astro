---
import PublicationList from './PublicationList.astro';
import { firstAuthorPapers, coAuthoredPapers } from '../data/publications';
---

<section id="publications" class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-gray-900">Scientific Publications</h2>
      <p class="mt-4 text-xl text-gray-600">Advancing medical knowledge through rigorous research</p>
    </div>

    <div class="flex justify-end mb-6">
      <div class="flex gap-4">
        <a 
          href="https://www.scopus.com/authid/detail.uri?authorId=57189597372"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center text-primary hover:text-secondary"
        >
          View on Scopus
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
        <a 
          href="https://pubmed.ncbi.nlm.nih.gov/?term=charles+rabolli&sort=date"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center text-primary hover:text-secondary"
        >
          View on PubMed
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>
    </div>

    <div class="space-y-16">
      <div>
        <h3 class="text-2xl font-semibold text-gray-900 mb-6">First Author Publications</h3>
        <PublicationList publications={firstAuthorPapers} />
      </div>

      <div>
        <h3 class="text-2xl font-semibold text-gray-900 mb-6">Co-authored Publications</h3>
        <PublicationList publications={coAuthoredPapers} />
      </div>
    </div>
  </div>
</section>